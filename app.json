{
  "expo": {
    "name": "HYG Portal",
    "slug": "hyg-portal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/hyg_icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/hyg_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#071426"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.hyg.portal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/hyg_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "b0a75d0f-14f4-432f-a404-9b2a62805c4d"
      }
    }
  }
}
